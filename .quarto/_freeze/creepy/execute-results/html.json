solid solid solid; border-width: 0.4pt 0pt 0pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">0.8%</td></tr>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">Christianity</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;\">74</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">55.6%</td></tr>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">Islam</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;\">16</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">12.0%</td></tr>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">Judaism</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;\">2</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">1.5%</td></tr>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">None (atheism)</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;\">24</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">18.0%</td></tr>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0pt 0pt 0.4pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">Other</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0.4pt 0pt;\">16</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0.4pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">12.0%</td></tr>\n<tr>\n<th class=\"huxtable-cell huxtable-header\" style=\"border-style: solid solid solid solid; border-width: 0.4pt 0pt 0.4pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">Age</th><th class=\"huxtable-cell huxtable-header\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0.4pt 0pt 0.4pt 0pt;\"></th><th class=\"huxtable-cell huxtable-header\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0.4pt 0pt 0.4pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">&nbsp;&nbsp;&nbsp;</th></tr>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0.4pt 0pt 0pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">18 - 24</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0.4pt 0pt 0pt 0pt;\">108</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0.4pt 0pt 0pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">81.2%</td></tr>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">25 - 34</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;\">15</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">11.3%</td></tr>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">35 - 44</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;\">3</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">2.3%</td></tr>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">45 - 54</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;\">6</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">4.5%</td></tr>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0pt 0pt 0.4pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">55 - 64</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0.4pt 0pt;\">1</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0.4pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">0.8%</td></tr>\n</table>\n\n```\n\n:::\n:::\n\n\n\n\n### Creepy Occupations\n\nParticipants were asked to rate 21 occupations on a scale from 1 (*Not Creepy at all*) to 5 (*Very Creepy*)\n\n\n\n\n::: {.cell}\n\n```{.r .cell-code}\n# Get Occupation Labels\nocc_lab <- \n  cr_cln |> \n  select(contains(\"Occ\")) \n\nocc_val <- map_df(occ_lab,get_label_attribute)\n\n# Isolated Occupations\nocc <- \n  occ_val |> \n  pivot_longer(cols=Creepy_Occ_2:Creepy_Occ_22,\n               names_to = \"occ\") |> \n  select(value)\n\n# Occupation Analysis\nocc <- \n  cr_cln |> \n  rename_at(vars(contains(\"occ\")), ~ occ$value) |>\n  pivot_longer(cols = Clown:Meterologist,\n               names_to = \"jobs\",\n               values_to = \"score\") |> \n  mutate(jobs = as.factor(jobs),\n         color = ifelse(jobs %in% c(\"Funeral Director\",\n                                    \"Sex Shop Owner\",\n                                    \"Taxidermist\",\n                                    \"Clown\"),\"maroon\",\"grey\")) \n\n# Visualize\nocc |> \n  ggplot(aes(score,fct_inorder(jobs))) +\n  stat_summary(\n    fun = \"mean\",\n    geom = \"bar\",\n    aes(fill = color)\n  ) +\n  stat_summary(\n    fun.data = \"mean_se\",\n    geom = \"errorbar\"\n  ) +\n  theme_minimal() +\n  labs(\n    x = \"\\n\",\n    y = \"\\n\",\n    title = \"How Creepy is your Job?\",\n    subtitle = \"The <strong><span style = 'color:maroon;'>creepiest</span></strong> occupations replicate findings from McAndrew and Koehnke (2017)<br>\"\n  ) +\n  coord_cartesian(xlim=c(1,5)) +\n  scale_fill_identity() +\n  theme(\n    plot.title.position = \"plot\",\n    plot.title = element_text(face = \"bold\",\n                              size = 20),\n    plot.subtitle = element_markdown()\n  )\n```\n\n::: {.cell-output-display}\n![](creepy_files/figure-html/unnamed-chunk-3-1.png){width=672}\n:::\n:::\n\n::: {.cell}\n\n```{.r .cell-code}\nocc |> \n  group_by(jobs) |> \n  summarize(\n    Mean = mean(score),\n    SD = sd(score)\n  ) |> \n  arrange(desc(Mean)) |> \n  rename(Occupation = jobs) |> \n  hux() |> \n  theme_article()\n```\n\n::: {.cell-output-display}\n\n```{=html}\n<table class=\"huxtable\" data-quarto-disable-processing=\"true\"  style=\"margin-left: auto; margin-right: auto;\">\n<col><col><col><thead>\n<tr>\n<th class=\"huxtable-cell huxtable-header\" style=\"border-style: solid solid solid solid; border-width: 0.4pt 0pt 0.4pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">Occupation</th><th class=\"huxtable-cell huxtable-header\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0.4pt 0pt 0.4pt 0pt;\">Mean</th><th class=\"huxtable-cell huxtable-header\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0.4pt 0pt 0.4pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">SD</th></tr>\n</thead>\n<tbody>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0.4pt 0pt 0pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">Clown</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0.4pt 0pt 0pt 0pt;\">3.64</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0.4pt 0pt 0pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">1.32&nbsp;</td></tr>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">Sex Shop Owner</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;\">3.2&nbsp;</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">1.42&nbsp;</td></tr>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">Taxidermist</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;\">3.2&nbsp;</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 0pt 6pt 6pt;\">1.52&nbsp;</td></tr>\n<tr>\n<td class=\"huxtable-cell\" style=\"border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 6pt 6pt 0pt;\">Funeral Director</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;\">2.69</td><td class=\"huxtable-cell\" style=\"text-align: right;  border-style: solid solid solid solid; border-width: 0pt 0pt 0pt 0pt;    padding: 6pt 0pt 6p